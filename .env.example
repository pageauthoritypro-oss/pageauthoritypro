# Sanity configuration
NEXT_PUBLIC_SANITY_DATASET=
NEXT_PUBLIC_SANITY_PROJECT_ID=
SANITY_API_TOKEN=

# Optional: Production site URL for Presentation Tool
NEXT_PUBLIC_SITE_URL=

# Neon Postgres (contact form submissions)
DATABASE_URL=

# Cloudflare Turnstile (contact form bot protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Shared secret required by the Sanity Studio contact-submissions tool
# (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
STUDIO_API_SECRET=
NEXT_PUBLIC_STUDIO_API_SECRET=
NEXT_PUBLIC_STUDIO_ALLOWED_URLS=
